{
  "name": "forca-app",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicativo de treinamento personalizado com foco em UX e performance",
  "scripts": {
    "android:dev": "ENVFILE=.env.development react-native run-android",
    "ios:dev": "ENVFILE=.env.development react-native run-ios",
    "android:prod": "ENVFILE=.env.production react-native run-android",
    "ios:prod": "ENVFILE=.env.production react-native run-ios",
    "start:dev": "ENVFILE=.env.development react-native start",
    "start:prod": "ENVFILE=.env.production react-native start",
    "start": "expo start",
    "backend:dev": "python3 -m backend.app",
    "backend:dev:debug": "FLASK_DEBUG=true python3 -m backend.app",
    "test": "jest",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "clean": "react-native-clean-project",
    "clean:android": "cd android && ./gradlew clean",
    "pods": "cd ios && pod install",
    "pods:clean": "cd ios && pod deintegrate && pod install",
    "pods:update": "cd ios && pod update",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:android:bundle": "cd android && ./gradlew bundleRelease",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.4.1",
    "@supabase/supabase-js": "^2.49.3",
    "axios": "^1.8.4",
    "date-fns": "^2.30.0",
    "expo": "^54.0.36",
    "expo-asset": "~12.0.13",
    "expo-checkbox": "~5.0.8",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "jest-expo": "~54.0.17",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.47.0",
    "react-native": "0.81.5",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-vector-icons": "^10.0.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "yup": "^1.3.2",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.22.20",
    "@babel/runtime": "^7.23.0",
    "@react-native/eslint-config": "^0.72.2",
    "@react-native/metro-config": "^0.72.11",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.5",
    "@types/lodash": "^4.14.199",
    "@types/react": "~19.1.0",
    "@types/react-native-vector-icons": "^6.4.15",
    "@typescript-eslint/eslint-plugin": "^6.7.3",
    "@typescript-eslint/parser": "^6.7.3",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.50.0",
    "eslint-plugin-jest": "^27.4.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^14.0.1",
    "metro-react-native-babel-preset": "^0.77.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.0.3",
    "react-native-clean-project": "^4.0.1",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ]
  },
  "main": "node_modules/expo/AppEntry.js"
}
