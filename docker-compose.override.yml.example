# Override de produção da VPS Hostinger — copie para docker-compose.override.yml
# no diretório de deploy (/docker/forcaapp). O Compose aplica overrides
# automaticamente, sem precisar de -f.
#
# POR QUE ISTO EXISTE (trava de segurança, não preferência):
# a chain DOCKER-USER desta VPS está vazia, então portas publicadas pelo
# Docker FURAM o UFW — um `ports: "5001:5001"` deixa o backend acessível
# na internet mesmo com o firewall fechado. Por isso o bind é somente em
# loopback; a exposição pública passa por nginx + TLS
# (proxy_pass http://127.0.0.1:5001).
#
# Sem este arquivo, o docker-compose.yaml versionado publica 5001 em 0.0.0.0.
services:
  backend:
    ports: !override
      - "127.0.0.1:5001:5001"
