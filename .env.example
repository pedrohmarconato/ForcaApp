// ============================================================
// Frontend (Expo / React Native) — vai no bundle do app (público)
// NUNCA coloque chaves secretas com o prefixo EXPO_PUBLIC_
// ============================================================

EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY_DO_SUPABASE

# URL do backend Flask. Em dispositivo físico, use o IP da sua máquina
# na rede local (ex: http://192.168.0.10:5001/api)
EXPO_PUBLIC_API_BASE_URL=http://localhost:5001/api

# ============================================================
# Backend (Flask) — NUNCA vai no app. Somente no servidor.
# ============================================================

# Chave da Anthropic usada SOMENTE pelo backend (proxy do Claude)
ANTHROPIC_API_KEY=sk-ant-SUA-CHAVE-AQUI

# Modelo Claude usado pelo backend (opcional; padrão claude-sonnet-4-6, ativo)
# NÃO usar claude-3-5-sonnet-20240620 — aposentado em 2025-10-28, requests falham.
CLAUDE_MODEL_NAME=claude-sonnet-4-6

# Credenciais Supabase para o backend validar os tokens JWT dos usuários
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA_ANON_KEY_DO_SUPABASE

# Origens permitidas para CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Ativa o modo debug do Flask (true/false). Sempre false em produção.
FLASK_DEBUG=false

# Porta do servidor Flask (opcional, padrão 5001)
PORT=5001

# Timeout (segundos) das chamadas à Anthropic no backend.
# Deve ser MENOR que o timeout do app (180s) para não cobrar geração perdida.
ANTHROPIC_TIMEOUT_SECONDS=150

# Rate limit por usuário (janela em segundos).
# ATENÇÃO: em memória — reinícios zeram e múltiplos workers multiplicam o
# limite efetivo. Para produção multi-worker, usar storage compartilhado.
CHAT_RATE_LIMIT=10
CHAT_RATE_WINDOW_SECONDS=60
PLAN_RATE_LIMIT=3
PLAN_RATE_WINDOW_SECONDS=3600
